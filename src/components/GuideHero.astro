---
interface Props {
  guideBreadcrumb: string;
  guideSlug: string;
  title: string;
  description: string;
  stats: string;
  image: string;
}

const { guideBreadcrumb, guideSlug, title, description, stats, image } = Astro.props;
---

<header class="mb-8 text-center">
  <p class="text-sm text-brand mb-2">
    <a href="/guides" class="hover:text-brand-hover transition-colors">Guides</a>
    {guideBreadcrumb && (
      <>{" / "}<a href={`/guides/${guideSlug}`} class="hover:text-brand-hover transition-colors">{guideBreadcrumb}</a></>
    )}
  </p>
  <h1 class="text-4xl font-bold text-gray-900 leading-tight">
    {title}
  </h1>
  <p class="mt-3 text-lg text-gray-500 max-w-2xl mx-auto">{description}</p>
  <p class="mt-2 text-sm text-gray-400">{stats}</p>
  <img
    src={image}
    alt={title}
    class="mt-8 mx-auto max-w-2xl w-full"
  />
</header>
