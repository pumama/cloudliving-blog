---
import type { Heading } from "../lib/guides";

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <aside class="space-y-4">
    <p class="text-xs font-medium uppercase tracking-wide text-gray-400">
      On this page
    </p>
    <nav class="space-y-1">
      {headings.map((h) => (
        <a
          href={`#${h.id}`}
          class:list={[
            "block text-sm text-gray-500 hover:text-brand transition-colors leading-relaxed",
            h.level === 3 && "pl-4",
          ]}
        >
          {h.text}
        </a>
      ))}
    </nav>
  </aside>
)}
