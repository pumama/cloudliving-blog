---
import type { Post } from "../lib/posts";

interface Props {
  post: Post;
}

const { post } = Astro.props;

const dateStr = new Date(post.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const tagStr = post.tags.length > 0 ? " · " + post.tags.join(", ") : "";
---

<article class="py-5">
  <a href={`/${post.slug}`} class="group block">
    <h3 class="text-base font-medium text-gray-900 group-hover:text-brand transition-colors">
      {post.title}
    </h3>
    {post.description && (
      <p class="mt-1 text-sm text-gray-500 line-clamp-2">{post.description}</p>
    )}
    <p class="mt-2 text-xs text-gray-400">
      {dateStr} &middot; {post.category}{tagStr} &middot; {post.readingTime}
    </p>
  </a>
</article>
