---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Cloud Living — Tung Tran",
  description = "Personal blog by Tung Tran. Lessons from building internet businesses, investing, and living life on my own terms.",
} = Astro.props;

const pageTitle = title === "Cloud Living — Tung Tran" ? title : `${title} — Cloud Living`;
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Cloud Living" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Cloud Living" href="/feed.xml" />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-full flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
