---
import Layout from "../../layouts/Layout.astro";
import GuideCard from "../../components/GuideCard.astro";
import { getAllGuides } from "../../lib/guides";

const guides = getAllGuides();
---

<Layout title="Guides" description="In-depth guides on building internet businesses, coding with AI, and more.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-10 sm:py-16">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Guides</h1>
    <p class="text-gray-500 mb-8">
      In-depth, multi-chapter guides on topics I know well. Each one is designed to take you from zero to competent.
    </p>

    <div class="space-y-4">
      {guides.map((guide) => <GuideCard guide={guide} />)}
    </div>

    {guides.length === 0 && (
      <p class="text-gray-400 text-sm py-8">No guides yet.</p>
    )}
  </div>
</Layout>
