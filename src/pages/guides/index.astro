---
import Layout from "../../layouts/Layout.astro";
import GuideCard from "../../components/GuideCard.astro";
import { getAllGuides } from "../../lib/guides";

const guides = getAllGuides();
---

<Layout title="Guides" description="In-depth guides on building internet businesses, coding with AI, and more.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-10 sm:py-16">
    <h1 class="text-2xl font-bold text-gray-900 mb-4">Guides</h1>
    <p class="text-gray-500 leading-relaxed mb-4">
      I write guides to break down topics I've spent years learning:
    </p>
    <div class="bg-gray-50 rounded-xl p-5 mb-8 text-gray-600 leading-relaxed space-y-3">
      <ul class="list-disc pl-5 space-y-3">
        <li>I pick a topic I have real, hands-on experience with.</li>
        <li>I research deeply and question the conventional wisdom. If something doesn't match my experience, I say so.</li>
        <li>I use AI to help with research and drafting — then I personally rewrite, edit, and add my own stories and lessons until every chapter sounds like me.</li>
        <li>"The difference between knowledge and wisdom is experience," so I only write about things I've actually done.</li>
        <li>I release each guide for free.</li>
      </ul>
    </div>

    <div class="space-y-4">
      {guides.map((guide) => <GuideCard guide={guide} />)}
    </div>

    {guides.length === 0 && (
      <p class="text-gray-400 text-sm py-8">No guides yet.</p>
    )}
  </div>
</Layout>
